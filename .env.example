# The x-ui / 3x-ui panel this checker talks to.
# Include the web base path if your panel uses one, e.g.
#   https://panel.example.com:2053/mysecretpath
PANEL_BASE_URL=https://panel.example.com:2053/mysecretpath

# Panel login. This service logs in as the admin to read client usage,
# so keep these secret and run the checker somewhere only you control.
PANEL_USERNAME=admin
PANEL_PASSWORD=admin

# API path prefix.
#   alireza0/x-ui  ->  /xui/API/inbounds   (default)
#   MHSanaei/3x-ui ->  /panel/api/inbounds
PANEL_API_BASE=/xui/API/inbounds

# Set to "false" if your panel uses a self-signed TLS certificate.
PANEL_VERIFY_TLS=true
